# Blog Money - Apache Config
Options -Indexes

# Blocca accesso a file sensibili
<FilesMatch "\.(env|log|sql|md|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Blocca accesso alle cartelle interne
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Blocca includes/ e cron/ dal web
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^cron/ - [F,L]

    # URL puliti per articoli (opzionale)
    # RewriteRule ^articolo/([a-z0-9-]+)/?$ public/articolo.php?slug=$1 [QSA,L]
</IfModule>

# Compressione
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache statici
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
</IfModule>
